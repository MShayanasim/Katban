{
  "manifest_version": 3,
  "name": "Katban",
  "version": "1.0.0",
  "description": "Your interactive cat companion. Features a Pomodoro timer, site blocker, AI support chat, tasks, and a secure clipboard manager.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Katban"
  },
  "icons": {
    "16": "katban-icon-16.png",
    "48": "katban-icon-48.png",
    "128": "katban-icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open Katban Popup"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src 'self' https://katban-ai-worker.shayanasim-dev.workers.dev https://api.dictionaryapi.dev;"
  }
}
